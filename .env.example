# Copy to .env for local overrides. Defaults already match docker-compose.yml.
AEGIS_ENVIRONMENT=local
AEGIS_LOG_LEVEL=INFO
AEGIS_POSTGRES_DSN=postgresql+asyncpg://aegis:aegis@localhost:5432/aegis
AEGIS_REDIS_URL=redis://localhost:6379/0
AEGIS_KAFKA_BOOTSTRAP=localhost:9092
AEGIS_OTEL_ENDPOINT=http://localhost:4317
AEGIS_QDRANT_URL=http://localhost:6333
AEGIS_OLLAMA_URL=http://localhost:11434

# Service-specific
AEGIS_INGEST_TOKEN=dev-ingest-token
AEGIS_TOPOLOGY_PATH=deploy/local/topology.example.json
# AEGIS_NOTIFY_WEBHOOK=https://hooks.example.com/...
